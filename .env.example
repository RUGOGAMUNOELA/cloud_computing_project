# SkyPipe — copy to .env (see scripts/Configure-SkyPipe.ps1)

# --- Auth (React admin login) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=skypipe
JWT_SECRET=replace-with-long-random-string

# --- CORS (Vite dev + Docker web) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000

# --- Optional GCP (GCS uploads when configured) ---
GCP_PROJECT=
GCS_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Optional S3 / MinIO (set automatically in docker-compose; empty = local disk) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=skypipe-uploads
S3_USE_SSL=false

# --- Local data + DuckDB warehouse ($0) ---
LOCAL_DATA_ROOT=
DUCKDB_PATH=

SPARK_MASTER=local[*]
